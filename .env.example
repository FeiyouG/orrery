# ── Brand Solar System configuration ────────────────────────────────
# Copy this file to .env and fill in the values. Never commit .env.

# The company or brand to visualize. Used as the search term across all
# data sources (Twitter, LinkedIn, news, Google Trends, ...), so use the
# name people actually write, e.g. "OpenAI", "Airbnb", "Notion".
COMPANY_NAME=OpenAI

# Monid API key — create one at https://app.monid.ai/access/api-keys
# Format: monid_<stage>_<secret>
#   monid_live_...  -> production key
#   monid_test_...  -> test/dev key
MONID_API_KEY=monid_live_xxxxxxxxxxxxxxxxxxxx

# Monid API base URL. Must match the key's environment:
#   live keys -> https://api.monid.ai
#   test keys -> https://api.dev.monid.ai
MONID_API_BASE_URL=https://api.monid.ai
