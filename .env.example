# ── Signal Solar System configuration ───────────────────────────────
# Copy this file to .env and fill in the values. Never commit .env.

# The subject to visualize — a company OR a topic. Used as the search
# term across all data sources, so use the name people actually write:
#   companies: "OpenAI", "Airbnb", "Notion"
#   topics:    "GPT-5.6", "AI agents", "rust lang"
SUBJECT=OpenAI

# Optional: how to treat the subject. Default "auto" asks PDL — if it
# recognizes the subject as a company you also get company intel planets
# (LinkedIn profile, Instagram/TikTok accounts, workplace reviews, Akta
# valuation/revenue). Topics use keyword search everywhere instead.
#   auto | company | topic
SUBJECT_TYPE=auto

# Monid API key — create one at https://app.monid.ai/access/api-keys
# Format: monid_<stage>_<secret>
#   monid_live_...  -> production key
#   monid_test_...  -> test/dev key
MONID_API_KEY=monid_live_xxxxxxxxxxxxxxxxxxxx

# Monid API base URL. Must match the key's environment:
#   live keys -> https://api.monid.ai
#   test keys -> https://api.dev.monid.ai
MONID_API_BASE_URL=https://api.monid.ai
